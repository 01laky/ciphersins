flowchart TB
	subgraph INPUT["Scan input"]
		direction LR
		PATHS["paths · cwd · ~/ expansion"]
		GLOBS["include / exclude globs"]
		CONFIG["ciphersins.config.json · optional"]
		FILTERS["only / ignore · suppressions"]
	end

	subgraph RESOLVE["File resolution · ciphersins"]
		direction TB
		ROOT["resolveDefaultScanRoot()"]
		RF["resolveFiles() · tinyglobby · realpath dedupe"]
		META["scannedFiles · skippedPaths with reason"]
		ROOT --> RF --> META
	end

	subgraph PARSE["TypeScript compiler API"]
		direction TB
		PSF["parseSourceFile() · BOM strip · size limit"]
		SF["SourceFile AST"]
		ERR["parseErrors collected · scan continues"]
		PSF --> SF
		PSF --> ERR
	end

	subgraph RULES["Rule engine"]
		direction TB
		REG["allRules · 12 rules"]
		CTX["createRuleContext() · frozen"]
		RUN["runRules() · per file · try/catch"]
		SUP["applySuppressions()"]
		REG --> RUN
		CTX --> RUN
		RUN --> SUP
		SUP --> FINDINGS["Finding[]"]
	end

	subgraph REPORT["Reporting · ciphersins"]
		direction TB
		SORT["sortFindings() · locale-independent"]
		JSON["formatJson() · schemaVersion 2"]
		SARIF["formatSarif() · SARIF 2.1.0"]
		SORT --> JSON
		SORT --> SARIF
	end

	subgraph OUTPUT["CLI output"]
		direction LR
		SUM["summary by severity"]
		PRETTY["pretty · snippet frame · colors"]
		JOUT["json · stdout / --output"]
		SOUT["sarif · stdout / --output"]
		FAIL["--fail-on · exit 0 / 1 / 2 / 3 / 4"]
	end

	PATHS --> ROOT
	GLOBS --> RF
	CONFIG --> FAIL
	FILTERS --> RUN
	META --> PSF
	SF --> CTX
	FINDINGS --> SUM
	SUM --> SORT
	JSON --> JOUT
	SARIF --> SOUT
	SUM --> PRETTY
	SUM --> FAIL

	classDef input fill:#0f172a,stroke:#38bdf8,stroke-width:2px,color:#e0f2fe
	classDef resolve fill:#1e1b4b,stroke:#818cf8,stroke-width:2px,color:#ede9fe
	classDef parse fill:#042f2e,stroke:#2dd4bf,stroke-width:2px,color:#ccfbf1
	classDef rules fill:#431407,stroke:#fb923c,stroke-width:2px,color:#ffedd5
	classDef report fill:#312e81,stroke:#a78bfa,stroke-width:2px,color:#ede9fe
	classDef output fill:#172554,stroke:#60a5fa,stroke-width:2px,color:#dbeafe

	class PATHS,GLOBS,CONFIG,FILTERS input
	class ROOT,RF,META resolve
	class PSF,SF,ERR parse
	class REG,CTX,RUN,SUP,FINDINGS rules
	class SORT,JSON,SARIF report
	class SUM,PRETTY,JOUT,SOUT,FAIL output
