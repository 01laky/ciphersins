{
	"name": "ciphersins",
	"version": "1.0.0",
	"description": "Static scanner for JWT, timing, RNG, and password-hashing footguns in Node/TS app code.",
	"license": "MIT",
	"author": "Ladislav Kostolny <01laky@gmail.com>",
	"type": "module",
	"keywords": [
		"security",
		"static-analysis",
		"sast",
		"jwt",
		"crypto-misuse",
		"bcrypt",
		"cli"
	],
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/01laky/CipherSins.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/01laky/CipherSins/issues"
	},
	"homepage": "https://github.com/01laky/CipherSins#readme",
	"bin": {
		"ciphersins": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"prepublishOnly": "node ../../scripts/sync-version.mjs && npm run build"
	},
	"dependencies": {
		"@ciphersins/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.15.29",
		"tsup": "^8.5.0"
	}
}
