{
	"name": "ciphersins",
	"version": "0.8.0",
	"description": "Static scanner for JWT, timing, RNG, and password-hashing footguns in Node/TS app code.",
	"license": "MIT",
	"author": "Ladislav Kostolny <01laky@gmail.com>",
	"type": "module",
	"keywords": [
		"security",
		"static-analysis",
		"sast",
		"jwt",
		"crypto-misuse",
		"bcrypt",
		"cli"
	],
	"engines": {
		"node": ">=18"
	},
	"bin": {
		"ciphersins": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@ciphersins/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.15.29",
		"tsup": "^8.5.0"
	}
}
