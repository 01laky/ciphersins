{
	"name": "@ciphersins/core",
	"version": "1.0.0",
	"description": "CipherSins scan engine — AST rules for crypto API misuse in TypeScript/JavaScript",
	"license": "MIT",
	"author": "Ladislav Kostolny <01laky@gmail.com>",
	"type": "module",
	"keywords": [
		"security",
		"static-analysis",
		"sast",
		"crypto-misuse",
		"jwt",
		"typescript"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/01laky/CipherSins.git",
		"directory": "packages/core"
	},
	"bugs": {
		"url": "https://github.com/01laky/CipherSins/issues"
	},
	"homepage": "https://github.com/01laky/CipherSins#readme",
	"files": [
		"dist"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"prepublishOnly": "node ../../scripts/sync-version.mjs && npm run build"
	},
	"dependencies": {
		"tinyglobby": "^0.2.14",
		"typescript": "^5.8.3"
	},
	"devDependencies": {
		"@types/node": "^22.15.29",
		"tsup": "^8.5.0"
	}
}
